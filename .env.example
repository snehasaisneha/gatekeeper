# App Config
APP_NAME="Gatekeeper"
APP_URL="http://localhost:8000"
FRONTEND_URL="http://localhost:4321"
SECRET_KEY="your-secret-key-min-32-chars-long-here"

# Database
DATABASE_URL="sqlite+aiosqlite:///./gatekeeper.db"
# DATABASE_URL="postgresql+asyncpg://user:pass@localhost/gatekeeper"

# Email - Common
EMAIL_PROVIDER="ses"  # or "smtp"
EMAIL_FROM_NAME="Gatekeeper"

# Email - SES
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
SES_FROM_EMAIL="noreply@yourdomain.com"

# Email - SMTP
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL=""

# Auth Config
ACCEPTED_DOMAINS="yourdomain.com,anotherdomain.com"
OTP_EXPIRY_MINUTES=5
SESSION_EXPIRY_DAYS=30
COOKIE_DOMAIN=".yourdomain.com"  # Use a leading dot for sibling-subdomain SSO in production
OTP_SEND_LIMIT_PER_EMAIL_IP=3
OTP_VERIFY_FAIL_LIMIT_PER_EMAIL_IP=8
AUTH_FAILURE_WINDOW_MINUTES=15
AUTO_IP_BAN_FAILURE_THRESHOLD=10
AUTO_IP_BAN_DURATION_HOURS=1

# Multi-App Config
DEFAULT_APP_ACCESS="allow"  # or "deny"

# WebAuthn
WEBAUTHN_RP_ID="localhost"
WEBAUTHN_RP_NAME="Gatekeeper"
WEBAUTHN_ORIGIN="http://localhost:4321"

# OAuth - Google (optional, enables "Sign in with Google")
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OAuth - GitHub (optional, enables "Sign in with GitHub")
# Get credentials from: https://github.com/settings/developers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Server
SERVER_HOST="0.0.0.0"
SERVER_PORT=8000
SERVER_RELOAD=true  # Set to false in production
PUBLIC_API_DOCS=false  # Keep false in production unless you explicitly want public Swagger/OpenAPI
TRUSTED_PROXY_IPS="127.0.0.1,::1"  # Add routing/nginx private IPs or CIDRs that are allowed to set forwarded client IP headers
